# === Supabase PostgreSQL 云数据库（必填）===
# 1. 注册 https://supabase.com（免费）
# 2. 创建项目 → Settings → Database
# 3. Connection string → Transaction mode → 复制连接字符串
# 格式: postgresql://postgres.[项目ID]:[密码]@aws-0-[区域].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxxx:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# JWT密钥（必填）
JWT_SECRET=your-jwt-secret-change-me

# 服务端口
PORT=3008

# 基础URL
BASE_URL=http://localhost:3008

# 百度AI识图API（可选，不配置则识图功能不可用）
BAIDU_API_KEY=your-baidu-api-key
BAIDU_SECRET_KEY=your-baidu-secret-key

# AI客服API（可选，不配置则使用本地知识库）
SILICONFLOW_API_KEY=your-siliconflow-api-key
